generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PARTICIPANT
  ORGANISATEUR
  SCANNER
  EXPOSANT
  SPEAKER
  SUPER_ADMIN
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  CANCELLED
}

enum TicketType {
  VIP
  STANDARD
  FREE
  EARLY_BIRD
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED
  EXPIRED
}

enum SponsorTier {
  PLATINUM
  GOLD
  SILVER
  BRONZE
}

enum RegistrationStatus {
  CONFIRMED
  PENDING
  CANCELLED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum NetworkingRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  role       UserRole @default(PARTICIPANT)
  password   String?
  avatar     String?
  phone      String?
  companyId  String?  @map("company_id")
  company    Company? @relation(fields: [companyId], references: [id])
  
  organizedEvents  Event[]             @relation("EventOrganizer")
  tickets          Ticket[]
  registrations    Registration[]
  notifications    Notification[]
  sentRequests     NetworkingRequest[] @relation("Sender")
  receivedRequests NetworkingRequest[] @relation("Receiver")

  @@map("users")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  description String
  logo        String?
  website     String?
  phone       String?
  email       String
  address     String?
  createdAt   DateTime @default(now()) @map("created_at")

  users       User[]
  events      Event[]

  @@map("companies")
}

model Event {
  id                  String      @id @default(cuid())
  title               String
  dateStart           DateTime    @map("date_start")
  dateEnd             DateTime    @map("date_end")
  location            String
  status              EventStatus @default(DRAFT)
  organiserId         String      @map("organiser_id")
  organiser           User        @relation("EventOrganizer", fields: [organiserId], references: [id])
  description         String
  banner              String?
  companyId           String      @map("company_id")
  company             Company     @relation(fields: [companyId], references: [id])
  attendeesCount      Int         @default(0) @map("attendees_count")
  ticketsSold         Int         @default(0) @map("tickets_sold")
  revenue             Float       @default(0)
  category            String?
  dateEndRegistration DateTime?   @map("date_end_registration")
  dateWithHours       String?     @map("date_with_hours")
  typeTicket          String?     @map("type_ticket")
  price               Float?      @default(0)

  rooms               Room[]
  sessions            Session[]
  tickets             Ticket[]
  exposants           Exposant[]
  sponsors            Sponsor[]
  registrations       Registration[]
  networkingRequests  NetworkingRequest[]

  @@map("events")
}

model Room {
  id       String @id @default(cuid())
  name     String
  capacity Int
  eventId  String @map("event_id")
  event    Event  @relation(fields: [eventId], references: [id])

  sessions Session[]

  @@map("rooms")
}

model Session {
  id          String   @id @default(cuid())
  title       String
  description String?
  start       DateTime
  end         DateTime
  roomId      String   @map("room_id")
  room        Room     @relation(fields: [roomId], references: [id])
  eventId     String   @map("event_id")
  event       Event    @relation(fields: [eventId], references: [id])
  speakerId   String   @map("speaker_id")
  speaker     Speaker  @relation(fields: [speakerId], references: [id])

  @@map("sessions")
}

model Ticket {
  id      String       @id @default(cuid())
  userId  String?      @map("user_id")
  user    User?        @relation(fields: [userId], references: [id])
  eventId String       @map("event_id")
  event   Event        @relation(fields: [eventId], references: [id])
  type    TicketType   @default(STANDARD)
  price   Float
  status  TicketStatus @default(ACTIVE)

  qrCodes QrCode[]

  @@map("tickets")
}

model QrCode {
  id        String    @id @default(cuid())
  ticketId  String    @map("ticket_id")
  ticket    Ticket    @relation(fields: [ticketId], references: [id])
  code      String    @unique
  scanned   Boolean   @default(false)
  scannedBy String?   @map("scanned_by")
  scannedAt DateTime? @map("scanned_at")

  @@map("qr_codes")
}

model Speaker {
  id          String   @id @default(cuid())
  name        String
  email       String
  avatar      String?
  bio         String
  topic       String
  company     String?
  eventsCount Int      @default(0) @map("events_count")

  sessions    Session[]

  @@map("speakers")
}

model Exposant {
  id          String @id @default(cuid())
  name        String
  email       String
  company     String
  standNumber String @map("stand_number")
  eventId     String @map("event_id")
  event       Event  @relation(fields: [eventId], references: [id])

  @@map("exposants")
}

model Sponsor {
  id      String      @id @default(cuid())
  name    String
  company String
  tier    SponsorTier
  eventId String      @map("event_id")
  event   Event       @relation(fields: [eventId], references: [id])
  logo    String?

  @@map("sponsors")
}

model Registration {
  id           String             @id @default(cuid())
  userId       String             @map("user_id")
  user         User               @relation(fields: [userId], references: [id])
  eventId      String             @map("event_id")
  event        Event              @relation(fields: [eventId], references: [id])
  status       RegistrationStatus @default(PENDING)
  registeredAt DateTime           @default(now()) @map("registered_at")

  @@map("registrations")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id])
  title     String
  body      String
  read      Boolean          @default(false)
  type      NotificationType @default(INFO)
  createdAt DateTime         @default(now()) @map("created_at")

  @@map("notifications")
}

model NetworkingRequest {
  id         String                  @id @default(cuid())
  senderId   String                  @map("sender_id")
  sender     User                    @relation("Sender", fields: [senderId], references: [id])
  receiverId String                  @map("receiver_id")
  receiver   User                    @relation("Receiver", fields: [receiverId], references: [id])
  eventId    String                  @map("event_id")
  event      Event                   @relation(fields: [eventId], references: [id])
  status     NetworkingRequestStatus @default(PENDING)
  message    String
  createdAt  DateTime                @default(now()) @map("created_at")

  @@map("networking_requests")
}
